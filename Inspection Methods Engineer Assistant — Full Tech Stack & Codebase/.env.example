# =============================================================================
# INSPECTION METHODS ENGINEER ASSISTANT - ENVIRONMENT CONFIGURATION
# =============================================================================
# Copy this file to .env and fill in your actual values
# DO NOT commit .env file to version control

# =============================================================================
# AI/LLM CONFIGURATION (REQUIRED)
# =============================================================================
# Groq API Key - Get yours at: https://console.groq.com/
# This replaces OpenAI and provides faster, cost-effective inference
GROQ_API_KEY=your_groq_api_key_here

# =============================================================================
# MONITORING & ANALYTICS (OPTIONAL)
# =============================================================================
# LangWatch API Key for monitoring LLM interactions
# Get yours at: https://langwatch.ai/
LANGWATCH_API_KEY=your_langwatch_api_key_here

# =============================================================================
# DATABASE CONFIGURATION
# =============================================================================
# PostgreSQL Database Settings
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=inspection_assistant
POSTGRES_HOST=localhost
POSTGRES_PORT=5432

# =============================================================================
# MONITORING DASHBOARD
# =============================================================================
# Grafana Admin Configuration
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=admin123

# =============================================================================
# MCP SERVER CONFIGURATION (OPTIONAL)
# =============================================================================
# Model Context Protocol Server License
# Required for advanced standards/catalog tools
MCP_LICENSE_KEY=your_mcp_license_key_here

# =============================================================================
# APPLICATION SETTINGS
# =============================================================================
# Logging Configuration
LOG_LEVEL=INFO

# Environment Setting
ENVIRONMENT=development

# API Configuration
API_HOST=0.0.0.0
API_PORT=8000

# Streamlit Configuration
STREAMLIT_PORT=8501

# =============================================================================
# VECTOR DATABASE (ChromaDB)
# =============================================================================
# ChromaDB Configuration
CHROMA_HOST=localhost
CHROMA_PORT=8000
CHROMA_PERSIST_DIRECTORY=./chroma_db

# =============================================================================
# SECURITY SETTINGS
# =============================================================================
# JWT Secret for API authentication (generate a secure random string)
JWT_SECRET_KEY=your_jwt_secret_key_here

# CORS Settings
CORS_ORIGINS=http://localhost:8501,http://localhost:3000