# FastAPI configuration
API_TITLE=Corrosion Intelligence API
API_VERSION=0.1.0

# AWS configuration
AWS_REGION=us-east-1
# Uncomment if you use a named profile from ~/.aws/config
# AWS_PROFILE=default
# Uncomment to use static credentials (prefer profiles or IAM roles in production)
# AWS_ACCESS_KEY_ID=YOUR_ACCESS_KEY_ID
# AWS_SECRET_ACCESS_KEY=YOUR_SECRET_ACCESS_KEY
# AWS_SESSION_TOKEN=YOUR_SESSION_TOKEN
# AWS_ENDPOINT_URL=http://localhost:4566

# Dashboard data source
# Provide the S3 bucket and object key that contain dashboard JSON data.
# DASHBOARD_BUCKET=your-dashboard-bucket
# DASHBOARD_KEY=path/to/dashboard.json

# CORS configuration (comma-separated origins, or * for all)
CORS_ALLOWED_ORIGINS=http://localhost:5173
